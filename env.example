import {
  Controller,
  Get,
  Post,
  Put,
  Delete,
  Body,
  Param,
  Query,
  ParseIntPipe,
  HttpCode,
  HttpStatus,
} from '@nestjs/common';
import { StudentsService, QueryStudentsDto } from './students.service';
import { CreateStudentDto }                  from './dto/create-student.dto';
import { UpdateStudentDto }                  from './dto/update-student.dto';

// FIX: Removed per-route @UsePipes(new ValidationPipe(...)) duplications.
//      The global pipe in main.ts (whitelist + transform + forbidNonWhitelisted)
//      covers all routes. Adding a second pipe per route can cause double-validation
//      issues and contradictory settings.
@Controller('api/students')
export class StudentsController {
  constructor(private readonly studentsService: StudentsService) {}

  // ── GET /api/students ─────────────────────────────────────────────────────
  // ?search=&department=&status=&semester=&minGpa=&maxGpa=
  // &isActive=&sortBy=&order=asc|desc&page=&limit=
  @Get()
  findAll(@Query() query: QueryStudentsDto) {
    return this.studentsService.findAll(query);
  }

  // ── GET /api/students/stats ───────────────────────────────────────────────
  // NOTE: must be declared BEFORE :id so Express doesn't parse "stats" as an id
  @Get('stats')
  getStats() {
    return this.studentsService.getStats();
  }

  // ── GET /api/students/:id ─────────────────────────────────────────────────
  @Get(':id')
  findOne(@Param('id', ParseIntPipe) id: number) {
    return this.studentsService.findOne(id);
  }

  // ── POST /api/students ────────────────────────────────────────────────────
  @Post()
  @HttpCode(HttpStatus.CREATED)
  create(@Body() dto: CreateStudentDto) {
    return this.studentsService.create(dto);
  }

  // ── PUT /api/students/:id ─────────────────────────────────────────────────
  @Put(':id')
  update(
    @Param('id', ParseIntPipe) id: number,
    @Body() dto: UpdateStudentDto,
  ) {
    return this.studentsService.update(id, dto);
  }

  // ── DELETE /api/students/:id ──────────────────────────────────────────────
  @Delete(':id')
  @HttpCode(HttpStatus.OK)
  remove(@Param('id', ParseIntPipe) id: number) {
    return this.studentsService.remove(id);
  }
}
